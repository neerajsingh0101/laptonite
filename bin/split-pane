#!/usr/bin/env ruby

require "fileutils"

# Usage
# worktree <agent> <task description>
# e.g. worktree claude feature paypal

if ARGV.length < 2
  abort "ERROR: worktree expects an agent and a task description."
end

agent = ARGV.shift

# If inside a .claude, .codex or .pi subdirectory, navigate to just above it
current_dir = Dir.pwd
if current_dir.include?("/.#{agent}")
  Dir.chdir(current_dir.split("/.#{agent}").first)
end

# Create the worktree from the branch the user is currently on
base_branch = `git branch --show-current`.strip

# Abort if there is uncommitted work, since it would not be carried into the
# new worktree (worktrees are created from the committed tip of the branch)
unless `git status --porcelain`.strip.empty?
  abort("ERROR: You have uncommitted changes. Commit or stash them before creating a worktree.")
end

# Pull the latest changes if the branch is main
if base_branch == "main"
  system("git pull") || abort("git pull failed")
end

slug = ARGV.join("-")[0, 50]
worktree_path = "#{Dir.pwd}/.#{agent}/worktrees/#{slug}"
FileUtils.mkdir_p(worktree_path)

system("git", "worktree", "add", "-b", slug, worktree_path, base_branch) || abort("git worktree add failed")
Dir.chdir(worktree_path) do
  system("mise", "trust") || abort("mise trust failed")
end
sleep 1

repo_name = File.basename(Dir.pwd)
short_repo_name = repo_name
  .delete_prefix("neeto-")
  .delete_prefix("bigbinary-")
  .delete_suffix("-web")
short_slug = slug[0, 10]

system("wezterm", "cli", "set-tab-title", "#{short_repo_name} (#{short_slug})")

pane_id = `wezterm cli split-pane --right`.strip
system(
  "wezterm", "cli", "send-text",
  "--pane-id", pane_id,
  "--no-paste",
  "--",
  "cd #{worktree_path}\r"
)
sleep 2
system(
  "wezterm", "cli", "send-text",
  "--pane-id", pane_id,
  "--no-paste",
  "--",
  "sleep 1 && SIDEBAR_TITLE=#{short_slug} stl\r"
)
sleep 2

# Split the right pane horizontally: the existing pane (running stl) keeps the
# top 85%, and a new bottom pane (15%, half of the previous 30%) watches for
# the launch_url file.
url_pane_id = `wezterm cli split-pane --pane-id #{pane_id} --bottom --percent 15`.strip
system(
  "wezterm", "cli", "send-text",
  "--pane-id", url_pane_id,
  "--no-paste",
  "--",
  "cd #{worktree_path} && watch-launch-url\r"
)
sleep 2

if agent == "codex"
  exec("codex", "--dangerously-bypass-approvals-and-sandbox", "-C", worktree_path)
end

if agent == "claude"
  exec("claude", "--dangerously-skip-permissions", "--worktree", slug)
end

if agent == "pi"
  Dir.chdir(worktree_path) do
    exec("pi")
  end
end
