#!/usr/bin/env bash
#
# Merge laptonite's shared Claude Code settings into the real
# ~/.claude/settings.json.
#
# Why a merge instead of a symlink: Claude Code rewrites its settings file
# atomically (write a temp file, then rename it into place) whenever you change
# something through its own UI -- /model, /effort, /plugin, "always allow" on a
# permission prompt. That rename replaces a symlink with a detached regular
# file, so the old symlink approach silently stopped sharing after the first UI
# change. Merging into the real file survives all of it.
#
# What laptonite owns: permissions.allow, permissions.deny and hooks, all read
# from data/claude_settings.json. Everything else in your settings.json --
# theme, effortLevel, model, enabledPlugins -- is personal. This script never
# reads or writes those keys, so set them however you like.
#
# How removals reach you: ~/.claude/.laptonite-applied.json records what this
# script last applied. An entry laptonite applied before and has since dropped
# from the shared file gets removed. An entry you added yourself was never in
# that record, so it is left alone.
#
# The first run on a machine is different: with no applied record yet, it resets
# permissions and hooks and rebuilds them from the shared file. That clears out
# whatever the old symlinked settings.json left behind, so everyone lands in the
# same clean state whether they arrive with no settings.json, a live symlink, or
# a symlink that broke months ago.
#
# Runs from githooks/post-merge on every pull, from the daily auto-update in
# zsh/auto_update.zshrc, and from bin/setup. When nothing
# has changed it writes nothing at all -- and when something has changed, your
# previous settings.json is copied to settings.json-bkp-<timestamp> first, so
# there is always a copy of what you had before any edit this script made.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DATA="$REPO_ROOT/data/claude_settings.json"
CLAUDE_DIR="$HOME/.claude"
DST="$CLAUDE_DIR/settings.json"
APPLIED="$CLAUDE_DIR/.laptonite-applied.json"

# This runs from a git hook. Never block a pull: complain and leave.
skip() {
  echo "[laptonite] $1" >&2
  exit 0
}

# Pick <file>-bkp-<timestamp>, matching the convention bin/setup already uses.
# Two updates inside the same second must not land on the same name and quietly
# overwrite each other's backup, so fall back to a -2, -3 ... suffix.
backup_path() {
  local base="$1-bkp-$(date +%Y%m%d%H%M%S)"
  local candidate="$base"
  local n=2
  while [ -e "$candidate" ]; do
    candidate="$base-$n"
    n=$((n + 1))
  done
  printf '%s' "$candidate"
}

# Copy the current settings aside before we touch them. Only ever called when
# something is actually about to change.
backup_now() {
  local backup
  backup="$(backup_path "$DST")"
  cp -p -- "$DST" "$backup"
  echo "[laptonite] Backed up previous settings to $backup"
}

command -v jq >/dev/null 2>&1 ||
  skip "jq not found, skipping Claude settings update. Run bin/setup to install it."
[ -f "$DATA" ] || skip "missing $DATA, skipping Claude settings update."
jq -e . "$DATA" >/dev/null 2>&1 || skip "$DATA is not valid JSON, skipping."

mkdir -p "$CLAUDE_DIR"

# Migration: laptonite used to symlink settings.json into the repo. The repo
# file is gone now, so that link is dangling. Everything it held was laptonite's
# rather than yours, so drop it and rebuild from the shared file.
if [ -L "$DST" ]; then
  case "$(readlink "$DST")" in
    */symlinks/claude/settings.json)
      echo "[laptonite] Replacing the old Claude settings symlink with a real file."
      rm -f "$DST"
      ;;
  esac
fi

# Still a symlink? Then it is one you made, pointing somewhere of your own.
# Follow it and write the real file so our rename does not eat your link.
if [ -L "$DST" ]; then
  resolved="$(readlink -f "$DST" 2>/dev/null || true)"
  [ -n "$resolved" ] && DST="$resolved"
fi

# Read the current settings. Anything unreadable gets backed up rather than
# silently overwritten.
live='{}'
if [ -e "$DST" ]; then
  if jq -e . "$DST" >/dev/null 2>&1; then
    live="$(cat "$DST")"
  else
    echo "[laptonite] $DST is not valid JSON, starting from scratch."
    backup_now
    rm -f -- "$DST"
  fi
fi

# Keep hold of what is actually on disk. Everything below works on $live, which
# the first-run reset may rewrite, but "did anything change?" must compare
# against the real file or we would rewrite an already-correct settings.json.
on_disk="$live"

applied='{}'
first_run=true
if [ -f "$APPLIED" ] && jq -e . "$APPLIED" >/dev/null 2>&1; then
  applied="$(cat "$APPLIED")"
  first_run=false
fi

# First run on this machine: laptonite has never merged into this file, so
# whatever sits under permissions/hooks arrived from the old symlinked
# settings.json -- including entries and hooks laptonite has since dropped, like
# the afplay sounds removed in 8b551bf. With no applied record yet there is no
# way to tell those from something you added yourself, so reset both keys and
# rebuild them from the shared file. Your permissions.allow additions go too;
# re-approve them as they come up, or lift them out of the backup taken below.
# Everything outside permissions/hooks is untouched. From the second run on, the
# applied record makes removals surgical and this never happens again.
if [ "$first_run" = true ]; then
  live="$(printf '%s' "$live" | jq 'del(.permissions, .hooks)')"
fi

merged="$(jq -n \
  --argjson live "$live" \
  --argjson applied "$applied" \
  --argjson data "$(cat "$DATA")" '
  # Compare by value, not by text: key order must not make two identical hooks
  # look different.
  def canon: walk(if type == "object" then to_entries | sort_by(.key) | from_entries else . end);
  def ckey: canon | tojson;
  def dedupe: reduce .[] as $x ([]; if (map(ckey) | index($x | ckey)) then . else . + [$x] end);

  # Keep what is live, minus anything laptonite applied before and has since
  # dropped, plus anything in the shared file not already present.
  def merge_items($l; $a; $d):
    ($d | map(ckey)) as $dk
    | [ $a[] | ckey ] as $ak
    | [ $ak[] | select(. as $k | $dk | index($k) | not) ] as $retired
    | [ $l[] | (ckey) as $k | select($retired | index($k) | not) ] as $kept
    | ($kept | map(ckey)) as $kk
    | ($kept + [ $d[] | (ckey) as $k | select($kk | index($k) | not) ]) | dedupe;

  def merge_hooks($l; $a; $d):
    (($l | keys) + ($a | keys) + ($d | keys) | unique) as $events
    | reduce $events[] as $e ({};
        merge_items($l[$e] // []; $a[$e] // []; $d[$e] // []) as $m
        | if ($m | length) > 0 then . + {($e): $m} else . end
      );

  $live
  | .permissions.allow = merge_items(
      $live.permissions.allow // []; $applied.permissions.allow // []; $data.permissions.allow // [])
  | .permissions.deny = merge_items(
      $live.permissions.deny // []; $applied.permissions.deny // []; $data.permissions.deny // [])
  | merge_hooks($live.hooks // {}; $applied.hooks // {}; $data.hooks // {}) as $h
  | if ($h | length) > 0 then .hooks = $h else del(.hooks) end
')"

# What we are about to record as ours.
want_applied="$(jq -S -c '{
  permissions: { allow: (.permissions.allow // []), deny: (.permissions.deny // []) },
  hooks: (.hooks // {})
}' "$DATA")"
have_applied="$(printf '%s' "$applied" | jq -S -c '{
  permissions: { allow: (.permissions.allow // []), deny: (.permissions.deny // []) },
  hooks: (.hooks // {})
}')"

# Sorted keys so a pure reordering by Claude Code does not read as a change.
current="$(printf '%s' "$on_disk" | jq -S -c .)"
next="$(printf '%s' "$merged" | jq -S -c .)"

if [ "$current" = "$next" ] && [ "$want_applied" = "$have_applied" ]; then
  exit 0
fi

if [ "$current" != "$next" ]; then
  # Keep a copy of what you had before this edit. Only on a real change, so the
  # no-op runs that happen on every pull do not litter ~/.claude with backups.
  [ -e "$DST" ] && backup_now

  # Write the same way Claude Code does, so a concurrent write is a clean
  # last-one-wins rather than a torn file.
  tmp="$(mktemp "$DST.laptonite.XXXXXX")"
  printf '%s\n' "$merged" | jq . >"$tmp"
  chmod 644 "$tmp"
  mv -f -- "$tmp" "$DST"
  echo "[laptonite] Updated Claude settings in $DST"
fi

tmp_applied="$(mktemp "$APPLIED.XXXXXX")"
printf '%s\n' "$want_applied" | jq . >"$tmp_applied"
chmod 644 "$tmp_applied"
mv -f -- "$tmp_applied" "$APPLIED"
