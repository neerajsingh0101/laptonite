#!/usr/bin/env bash
#
# After a `git pull` (merge) in laptonite, check whether the Claude settings
# symlink is intact. If it was detached, the puller won't receive the shared
# settings update they just fetched -- tell them to run bin/setup. Warn-only.
DIR="$(cd "$(dirname "$0")" && pwd)"
"$DIR/lib/check-claude-symlink.sh" merge || true
